{
  "name": "app",
  "version": "0.1.0",
  "description": "Application de dactylographie multi-plateforme",
  "author": "Frederic Boutou",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json && electron-vite build",
    "preview": "electron-vite preview",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.3"
  },
  "build": {
    "appId": "com.keyboard.typing",
    "productName": "Clavier",
    "electronVersion": "31.7.7",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "AllmightySlumber",
      "repo": "Keyboard-app"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education",
      "artifactName": "Clavier-mac.${ext}"
    },
    "win": {
      "target": "nsis",
      "artifactName": "Clavier-win.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "category": "Education",
      "artifactName": "Clavier-linux.${ext}"
    }
  }
}
